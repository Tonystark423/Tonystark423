LEDGER_USER=admin
LEDGER_PASS=changeme
DB_PATH=ledger.db
FLASK_SECRET_KEY=changeme

# CoinStats API (optional — required for /api/prices and /api/prices/refresh)
# Get your free key at https://openapiv1.coinstats.app
COINSTATS_API_KEY=YOUR_COINSTATS_API_KEY
COINSTATS_CURRENCY=USD

# Stark Bank integration (optional — only needed for /api/sync/starkbank)
STARKBANK_ENVIRONMENT=sandbox
STARKBANK_PROJECT_ID=YOUR_PROJECT_ID
# Full PEM with literal \n escapes (no real newlines in .env files):
STARKBANK_PRIVATE_KEY=-----BEGIN EC PRIVATE KEY-----\nMHQCAQEE...\n-----END EC PRIVATE KEY-----
# Stamped on every imported row (CSV and Stark Bank sync)
LEDGER_BENEFICIAL_OWNER=Evan Jacob Burke
